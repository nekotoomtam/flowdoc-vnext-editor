{
  "name": "flowdoc-vnext-editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Product editor frontend for FlowDoc vNext.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4001 --strictPort",
    "dev:pdf-export-local": "node --env-file=../flowdoc-vnext-backend/.env.local ./node_modules/vite/bin/vite.js --host 127.0.0.1 --port 4001 --strictPort",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:live-draft-worker-smoke": "node scripts/run-live-draft-worker-smoke.mjs",
    "evidence:live-draft-xr2": "node scripts/run-live-draft-xr2-evidence.mjs",
    "evidence:live-draft-xr3": "node scripts/run-live-draft-xr3-form-evidence.mjs",
    "evidence:live-draft-xr4": "node scripts/run-live-draft-xr4-canvas-evidence.mjs",
    "evidence:live-draft-xr5": "node scripts/run-live-draft-xr5-evidence.mjs",
    "evidence:live-draft-mr1": "node scripts/run-live-draft-mr1-evidence.mjs",
    "check": "npm run type-check && npm run test && npm run build"
  },
  "dependencies": {
    "@flowdoc/text-engine-rust-wasm": "file:../flowdoc-vnext-core/packages/text-engine-rust-wasm",
    "@flowdoc/vnext-core": "file:../flowdoc-vnext-core",
    "lucide-react": "^1.22.0",
    "pdfjs-dist": "5.6.205",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
